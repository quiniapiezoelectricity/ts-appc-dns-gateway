# ==============================================================================
# Tailscale App Connector DNS Gateway — example configuration
# Copy to .env and fill in the values you need.
# ==============================================================================

# ------------------------------------------------------------------------------
# Authentication — provide either an auth key OR OAuth credentials, not both
# ------------------------------------------------------------------------------

# Option 1 — auth key from the Tailscale admin console.
# https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-...

# Option 2 — OAuth client credentials.
# Preferred for automated or ephemeral deployments.
# https://tailscale.com/kb/1215/oauth-clients
# TS_CLIENT_ID=
# TS_CLIENT_SECRET=

# Option 3 — no credentials. On first start, check the logs of appc-ts for an
# interactive auth URL and visit it in a browser to authorise the node.

# ------------------------------------------------------------------------------
# Node identity
# ------------------------------------------------------------------------------

# Hostname for this node as it appears in the tailnet.
# TS_HOSTNAME=appc-gateway

# ------------------------------------------------------------------------------
# Container images (production: pin immutable tags/digests)
# ------------------------------------------------------------------------------

# Renderer sidecar image (must include apk + jq install support).
# CONFIG_IMAGE=alpine:3.22

# Gateway data plane image.
# GATEWAY_IMAGE=teddysun/xray:latest

# DNS sidecar image.
# DNS_IMAGE=adguard/dnsproxy:latest

# Tailscale image ("stable" is preferred over "latest").
# TS_IMAGE=tailscale/tailscale:stable

# ------------------------------------------------------------------------------
# Virtual IP pool
# ------------------------------------------------------------------------------

# Virtual IP pool CIDR. Every App Connector on the same tailnet
# must use a unique, non-overlapping range. See README for guidance on choosing a CIDR.
# PRIVATEIP_CIDR=10.250.0.0/16
#
# Comma-separate multiple CIDRs for dual-stack or multi-pool setups.
# Strategy (UseIPv4 / UseIPv6 / UseIP) is auto-detected from the address families present.
# Example — dual-stack (IPv4 + IPv6 virtual pools):
# PRIVATEIP_CIDR=10.250.0.0/16,2001:0db8:3333:4444:5555:6666:7777::/112

# ------------------------------------------------------------------------------
# Advanced
# ------------------------------------------------------------------------------

# Upstream DNS resolvers used by the gateway, comma-separated.
# Each entry can be a plain IP or udp://, tcp:// (plain DNS over TCP), tls:// (DoT),
# https:// (DoH), h3:// (DoH/HTTP3), quic:// (DoQ), or sdns:// (DNSCrypt stamp).
# Hostname-based DoH works — the DNS sidecar uses its
# own bootstrap DNS to resolve server hostnames, independent of the gateway's DNS.
# Default: Cloudflare + Google DoH.
# DNS_UPSTREAM=https://cloudflare-dns.com/dns-query,https://dns.google/dns-query
#
# In networks where the default upstreams are inaccessible, set this to a resolver
# reachable from your server instead.

# Bootstrap DNS resolvers used to resolve upstream hostnames (e.g. DoH server names),
# comma-separated plain IP:port entries. These bypass the gateway's DNS entirely.
# Default covers Cloudflare + Google across both IPv4 and IPv6. Override if any are
# blocked in your network. If your upstreams are plain IPs, bootstrap is unused.
# DNS_BOOTSTRAP=1.1.1.1:53,[2606:4700:4700::1111]:53,8.8.8.8:53,[2001:4860:4860::8888]:53

# Set to any non-empty value to prevent the config renderer from overwriting
# ./config/dns.yaml on each start. Edit that file directly to customise the DNS sidecar
# (listen options, filtering, caching TTLs, additional upstreams, etc.). If the file
# is missing it will still be generated from DNS_UPSTREAM as a starting point.
# DNS_CUSTOM=1

# Set to any non-empty value to prevent the config renderer from overwriting
# ./config/gateway.json on each start. Edit that file directly to customise the
# gateway config. If the file is missing it will still be rendered from the template.
# GATEWAY_CUSTOM=1

# Outbound domain resolution strategy for the gateway.
# Default matches the default IPv4-only pool. Change alongside PRIVATEIP_CIDR — the
# pool constrains which address families the gateway can resolve at all.
# If the pool and the host's real network families do not line up, startup still
# succeeds and failures show up per request.
# Accepts: UseIP|UseIPv4|UseIPv6|UseIPv4v6|UseIPv6v4|ForceIP|ForceIPv4|ForceIPv6|ForceIPv4v6|ForceIPv6v4
# (AsIs is rejected — the container DNS points to the gateway itself, causing a routing loop.)
# DOMAIN_STRATEGY=UseIPv4

# Log verbosity for the gateway and DNS sidecar.
# Gateway levels: debug | info (logs every connection+DNS lookup) | warning | error | none
# DNS sidecar: only "debug" enables verbose output; all other values leave it quiet.
# Default: warning. For Tailscale verbosity use TS_TAILSCALED_EXTRA_ARGS=--verbose=1.
# LOGLEVEL=warning

# Name of the TUN interface created by the gateway.
# TUN_IF=gateway0

# Gateway variant directory to use. Defaults to "default".
# GATEWAY_VARIANT=default

# Extra arguments passed directly to the tailscaled daemon.
# https://tailscale.com/kb/1282/docker
# TS_TAILSCALED_EXTRA_ARGS=

# Expose an unauthenticated /healthz endpoint for container health checks.
# TS_ENABLE_HEALTH_CHECK=false

# Expose an unauthenticated /metrics endpoint for Prometheus scraping.
# TS_ENABLE_METRICS=false
